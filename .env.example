# =============================================================================
# SQA Food Delivery — Environment Configuration
# =============================================================================
# Copy this file to .env (Docker) or .env.local (local dev) and fill in your
# real values.  Never commit secrets to version control.
# =============================================================================

# ── Server ─────────────────────────────────────────────────────────────
# Listen port (default: 4000)
PORT=4000

# Node environment: "production", "development", or "test"
NODE_ENV=production

# ── Database (PostgreSQL) ──────────────────────────────────────────────
# Connection string (required)
DATABASE_URL=postgresql://user:password@host:5432/database

# ── Authentication (Better-Auth) ───────────────────────────────────────
# Secret key for signing auth tokens (REQUIRED in production — app crashes
# without it).  Generate with:  openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-random-64-char-string

# Public-facing base URL of the API (used for auth redirects, callbacks).
# Must match the URL users access the backend at, e.g.:
#   https://api.mydomain.com
#   https://mydomain.com
BETTER_AUTH_URL=http://localhost:4000

# ── CORS ───────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (frontend URLs that call the API)
CORS_ORIGIN=http://localhost:5173,http://localhost:4173

# ── Rate Limiting ──────────────────────────────────────────────────────
# Request body size limit (default: 20kb)
# BODY_LIMIT=20kb

# ── Orders ─────────────────────────────────────────────────────────────
# Automatically advance order statuses (pending → in_progress → delivered)
# on a timer.  Useful for demos.  Default: false
# AUTO_ADVANCE_ORDERS=false

# ── Logging ────────────────────────────────────────────────────────────
# Bun / console log level.  Production default: "info"
# LOG_LEVEL=info

# ── Management Panel (DEPRECATED — replaced by Better-Auth admin plugin) ──
# MANAGE_PASSWORD is no longer used. Admin access is now via Better-Auth
# admin roles. Set ADMIN_EMAIL and ADMIN_PASSWORD below.
# MANAGE_PASSWORD=deprecated

# ── Admin Account ─────────────────────────────────────────────────────
# Initial admin user created by seed script on first run.
# Change the password after first login.
ADMIN_EMAIL=admin@kgamay.com
ADMIN_PASSWORD=admin123456

# ── Legacy (may be unused with Better-Auth) ────────────────────────────
# JWT_SECRET=change-me-to-a-long-random-string
