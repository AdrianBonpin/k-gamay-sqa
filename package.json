{
  "name": "sqa-food-delivery",
  "version": "1.0.0",
  "private": true,
  "description": "Simple Food Delivery App — Monorepo (Express + SQLite backend, React + Vite frontend)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:backend dev:frontend",
    "dev:backend": "npm --workspace apps/backend run dev",
    "dev:frontend": "npm --workspace apps/frontend run dev",
    "build": "npm --workspace apps/frontend run build",
    "start": "npm --workspace apps/backend run start",
    "test": "npm-run-all test:backend test:frontend",
    "test:backend": "npm --workspace apps/backend run test",
    "test:frontend": "npm --workspace apps/frontend run test",
    "lint": "npm --workspace apps/frontend run lint",
    "format": "prettier --write '**/*.{ts,tsx,js,json,md,css,html}'"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "prettier": "^3.3.3"
  }
}
