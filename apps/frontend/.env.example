# URL used by the browser to call the backend. In dev, leave as /api so Vite's
# proxy forwards to the backend. In production, set to an absolute URL like
# https://api.example.com/api.
VITE_API_BASE_URL=/api

# Target for Vite's dev proxy ('/api' -> this URL). Only used at dev time.
VITE_API_PROXY=http://localhost:4000
